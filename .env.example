# Core runtime
LOG_LEVEL=INFO
LOG_FILE_ENABLED=true
DATA_DIR=./data
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
SERVER_STORAGE_TYPE=local
SERVER_STORAGE_URL=

# Auth
APP_KEY=grok2api
API_KEY=
PUBLIC_KEY=

# Optional: override frontend asset version to force browser cache refresh
# Example: APP_ASSET_VERSION=20260308b
APP_ASSET_VERSION=

# Optional: Cloudflare refresh integration
# FLARESOLVERR_URL=http://flaresolverr:8191
# CF_REFRESH_INTERVAL=600
# CF_TIMEOUT=60
